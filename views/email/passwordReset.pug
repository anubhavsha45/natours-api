extends baseEmail

block content
  p Hi #{firstName},

  p Forgot your password? Click the button below to reset it.

  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td(align='left')
          table(role='presentation', border='0', cellpadding='0', cellspacing='0')
            tbody
              tr
                td
                  a(href=url target='_blank') Reset your password

  p This password reset link is valid for only 10 minutes.

  p If the button above doesn't work, copy and paste this link into your browser:

  p
    a(href=url target='_blank') #{url}

  p If you didn’t request a password reset, please ignore this email.

  p — The Natours Team